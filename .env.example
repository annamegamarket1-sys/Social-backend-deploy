# База данных (Railway PostgreSQL — копируй из Railway Dashboard → твой PostgreSQL сервис → Connect)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT — любая длинная случайная строка
JWT_SECRET="замени_на_случайную_строку"

# Cloudinary (Cloudinary Dashboard → Settings → API Keys)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# URL фронтенда для CORS
CLIENT_URL="https://final-project-2-semester-480d2d.edu-gitlab.ru"

# Уровень логов
LOG_LEVEL="info"
